# Required. Server-side only, never exposed to the client.
ANTHROPIC_API_KEY=

# Optional. If set, rate limiting is enforced globally per IP via Upstash Redis.
# If omitted, falls back to an in-memory counter (fine for local dev, not for prod).
# Get these for free at https://console.upstash.com by creating a Redis database,
# or wire via Vercel's Upstash integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
